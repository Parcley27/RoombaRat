# AWS — create an IAM user with AmazonRekognitionReadOnlyAccess + AmazonSESFullAccess
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-2

# Box.com — create an app at developer.box.com, generate a developer token (60 min TTL)
BOX_CLIENT_ID=your_box_client_id
BOX_CLIENT_SECRET=your_box_client_secret
BOX_DEVELOPER_TOKEN=your_developer_token
BOX_FOLDER_ID=0   # 0 = root folder, or paste a specific folder ID

# Email — both addresses must be verified in AWS SES (sandbox mode)
SES_SENDER_EMAIL=roombarat@proton.me
ALERT_EMAIL=ddale1128@gmail.com

# Tuning
CAMERA_INDEX=0          # increment if Continuity Camera isn't index 0 (try 1 or 2)
CHECK_INTERVAL=2.0      # seconds between Rekognition API calls (costs money per call)
COOLDOWN=30.0           # seconds between alert emails so inbox doesn't explode
MIN_CONFIDENCE=70       # Rekognition label confidence threshold (0–100)

# Local YOLO detector (--detector yolo) — no AWS, runs every frame
YOLO_MIN_CONFIDENCE=0.35   # 0–1 detection threshold (lower = more sensitive)
YOLO_WEIGHTS=yolov8n.pt    # n=nano fastest; try yolov8s.pt for more accuracy
